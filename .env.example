# ==============================================================================
# BOILER AGENT CORE - ENVIRONMENT VARIABLES (MAU)
# Copy file nay thanh .env that va dien gia tri. KHONG commit .env that len Git.
# ==============================================================================

# --- LLM Provider: Groq ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_TEXT_MODEL=openai/gpt-oss-120b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Database: Supabase (PostgreSQL) ---
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_LOG_TABLE=boiler_agent_logs
SUPABASE_PROJECTS_TABLE=boiler_projects

# --- Vector DB: Qdrant (Dual-RAG) ---
QDRANT_URL=https://xxxxxxxxxxxxxxxxxxxx.qdrant.io
QDRANT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QDRANT_COLLECTION_KNOWLEDGE=boiler_knowledge_base
QDRANT_COLLECTION_HISTORY=boiler_incident_history
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
SHARED_KNOWLEDGE_TAG=shared
RAG_CHUNK_SIZE_WORDS=200
RAG_CHUNK_OVERLAP_WORDS=70

# --- Embedding: Google Gemini API (thay the fastembed/onnxruntime chay tai cho,
# tranh loi "Ran out of memory" tren may chu RAM thap). Lay API key mien phi tai:
# https://aistudio.google.com/apikey (goi free: 100 request/phut, 1000 request/ngay)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# --- Advanced RAG lite (Task 30-33): Hybrid Search + Rerank ---
# RAG_HYBRID_ALPHA: trong so gop diem dense(vector)/sparse(BM25). 1=chi dense
# (giong he he thong cu), 0=chi BM25 (khop tu khoa). 0.5 la can bang mac dinh.
RAG_HYBRID_ALPHA=0.5
# So ung vien lay RONG ra tu moi collection truoc khi rerank chon lai top_k cuoi.
RAG_CANDIDATE_POOL_SIZE=20
# Tran so diem scroll ra de danh BM25 moi lan hoi (tranh scroll toan bo kho neu
# kho qua lon - du dung cho quy mo 1 nha may).
RAG_BM25_SCROLL_CAP=500

# Cohere Rerank API (rerank-v3.5, da ngon ngu, ho tro tieng Viet) - lay API key
# mien phi tai: https://dashboard.cohere.com/api-keys (goi free du dung noi bo).
# BO TRONG neu chua co key: he thong tu dong bo qua buoc rerank, dung nguyen
# ket qua hybrid search (khong crash, chi giam chat luong xep hang lai).
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

# --- Telegram Bot (Kenh giao tiep voi Ky su Long) ---
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_ID=000000000
TELEGRAM_POLL_ENABLED=true
DEFAULT_PROJECT_ID=boiler_default

# --- App Config ---
APP_ENV=development
LOG_LEVEL=INFO
MAX_LOOP_COUNT=3
PORT=8000
